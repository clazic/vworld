# ═════════════════════════════════════════════
# 1. 민감정보 — API 키·시크릿 (커밋 절대 금지)
# ═════════════════════════════════════════════
**/config.toml
**/config.toml.local-backup
**/.env
.env

# ═════════════════════════════════════════════
# 2. 숨김 폴더 전체 — 도구·캐시·로컬 설정·계획서
#    모든 dot 디렉토리를 일괄 제외 (.git은 git이 자동 무시)
#    예: .cargo/ .claude/ .omc/ .idea/ .plan/
#        .playwright-mcp/ .understand-anything/
#        .docker-cargo/ .vw_demo/ .vw_*/
# ═════════════════════════════════════════════
.*/
**/.*/

# ═════════════════════════════════════════════
# 3. 작업 산출물 (실제 키가 박힐 수 있어 제외)
# ═════════════════════════════════════════════
*.zip
skills/output/
output/

# ═════════════════════════════════════════════
# 4. Rust 빌드 산출물
# ═════════════════════════════════════════════
/target
**/*.rs.bk
Cargo.lock

# ═════════════════════════════════════════════
# 5. 대용량 데이터·경계 (직접 적재 — opt-in 자원)
# ═════════════════════════════════════════════
*.sqlite
*.shp

# ═════════════════════════════════════════════
# 6. OS
# ═════════════════════════════════════════════
.DS_Store
Thumbs.db
