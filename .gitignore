# ═════════════════════════════════════════════
# 1. 민감정보 — API 키·시크릿 (커밋 절대 금지)
# ═════════════════════════════════════════════
**/config.toml
**/config.toml.local-backup
**/.env
.env

# ═════════════════════════════════════════════
# 2. 숨김 폴더 전체 — 도구·캐시·로컬 설정·계획서
#    모든 dot 디렉토리를 일괄 제외 (.git은 git이 자동 무시)
#    예: .cargo/ .claude/ .omc/ .idea/ .plan/
#        .playwright-mcp/ .understand-anything/
#        .docker-cargo/ .vw_demo/ .vw_*/
# ═════════════════════════════════════════════
.*/
**/.*/
# 예외: GitHub Actions 워크플로(.github)는 추적해야 함
!.github/
!.github/**

# ═════════════════════════════════════════════
# 3. 작업 산출물 (실제 키가 박힐 수 있어 제외)
# ═════════════════════════════════════════════
*.zip
skills/output/
output/

# ═════════════════════════════════════════════
# 4. Rust 빌드 산출물
# ═════════════════════════════════════════════
/target
**/*.rs.bk

# 배포 바이너리 — CI(.github/workflows/release.yml)가 빌드해 Releases 로 배포 (git 미보관)
# config.toml.example 등 app/ 내 텍스트 자산은 추적 유지 → 바이너리 4종만 제외
/app/vworld
/app/vworld-macos
/app/vworld-linux
/app/vworld-windows.exe

# ═════════════════════════════════════════════
# 5. 대용량 데이터·경계 (직접 적재 — opt-in 자원)
# ═════════════════════════════════════════════
*.sqlite
*.shp

# ═════════════════════════════════════════════
# 6. OS
# ═════════════════════════════════════════════
.DS_Store
Thumbs.db
