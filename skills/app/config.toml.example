# VWorld CLI 설정 — 본인의 VWorld OpenAPI 인증키를 입력하세요.
#
# 1) 키 발급: https://www.vworld.kr → 오픈API → 인증키 신청
# 2) 등록(권장): app/<OS별 바이너리> config add-key <발급받은_KEY>
#    예) ./vworld-macos config add-key ABCD1234-... --alias main
# 3) 또는 아래 [[keys]] 블록의 주석을 풀고 직접 입력
#
# 도메인 등록 키면 referer에 등록 도메인을 적습니다(무도메인 서버 키는 생략).

# [[keys]]
# key = "여기에-발급받은-인증키"
# referer = "https://your-domain.com"   # 도메인 등록 키인 경우에만

# 여러 키를 쓰면 키 풀로 자동 편입됩니다.
# [[keys]]
# key = "두-번째-키"
# alias = "key2"
